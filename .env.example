# ---- Twitch ----
# OAuth-Token deines Bot-Accounts (holen auf https://twitchapps.com/tmi/)
# Format: oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_TOKEN=oauth:DEIN_TOKEN_HIER

# Name deines Twitch-Kanals (kleingeschrieben)
TWITCH_CHANNEL=dein_kanalname

# Twitch-App für die Clip-API (optional, aber empfohlen für Clip Requests).
# App anlegen unter https://dev.twitch.tv/console/apps -> Client-ID + Secret.
# Damit holt der Bot echten Clip-Titel + -Länge und prüft, ob der Clip existiert.
# Leer lassen = Clips werden ohne Titel/Längenprüfung angenommen.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ---- Song Requests ----
# Max. Songlänge in Minuten (Standard: 7)
MAX_SONG_DURATION_MINUTES=7

# YouTube Data API v3 Key für Längencheck (https://console.cloud.google.com/)
# Leer lassen = Längencheck deaktiviert
YOUTUBE_API_KEY=

# ---- YouTube-Playlist-Sync (optional) ----
# Trägt akzeptierte Songrequests automatisch in eine echte YouTube-Playlist ein
# und entfernt sie bei skip/remove/wrongsong wieder.
# Benötigt OAuth (kein reiner API-Key!). Refresh Token einmalig mit
# get_refresh_token.py holen. Alle vier Werte setzen, sonst bleibt der Sync aus.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# Playlist-ID aus der Playlist-URL hinter list= (z.B. PLxxxxxxxxxxxx)
YOUTUBE_PLAYLIST_ID=
# Wo neue Songs in die Playlist einsortiert werden:
#   0   = ganz vorne / als Naechstes (Standard)
#   1   = an zweiter Stelle (hinter dem aktuell laufenden Song)
#   end = ans Ende anhaengen
YOUTUBE_INSERT_POSITION=0

# Zusätzliche gesperrte Begriffe im Titel, kommagetrennt (optional)
# Beispiel: BLOCKED_KEYWORDS=meme,troll,earrape
BLOCKED_KEYWORDS=

# Datei für die dauerhaft wachsende Streamliste (alle requesteten Songs)
# Standard: streamlist.txt im Bot-Verzeichnis
# Für Railway mit Volume (gemountet z.B. auf /data): STREAMLIST_FILE=/data/streamlist.txt
STREAMLIST_FILE=streamlist.txt

# Pfad zur SQLite-Datenbank (Queue + dauerhafte Streamliste)
# Standard: queue.db im Bot-Verzeichnis
# Für Railway mit Volume (gemountet z.B. auf /data): DB_PATH=/data/queue.db
DB_PATH=queue.db

# ---- Clip Requests (Twitch-Clips) ----
# Zuschauer reichen Clips mit !clip <Link> ein; das Overlay /clips spielt sie
# nacheinander ab (OBS-Browser-Quelle, mit ?token=PLAYER_TOKEN absichern).
# Da ohne Twitch-API die Clip-Länge unbekannt ist, wird nach so vielen Sekunden
# automatisch zum nächsten Clip geschaltet (Twitch-Clips sind max. 60 s).
CLIP_PLAY_SECONDS=35

# ---- Witze-Timer ----
# Interval in Minuten zwischen automatischen Witzen (Standard: 30)
JOKE_INTERVAL_MINUTES=30

# ---- Web-Player (OBS-Browser-Quelle) ----
# Geheimes Wort, um den Player/die Queue-API zu schuetzen. UNBEDINGT setzen,
# da die Railway-Domain oeffentlich erreichbar ist. Frei waehlbar.
PLAYER_TOKEN=
# Optionaler eigener Token nur fuer das Clip-Overlay (/clips). Wenn leer, wird
# PLAYER_TOKEN verwendet. URL: /clips?token=DEIN_CLIPS_TOKEN
CLIPS_TOKEN=
# PORT wird von Railway automatisch gesetzt - hier nichts eintragen.
