# ---- Twitch ----
# OAuth-Token deines Bot-Accounts (holen auf https://twitchapps.com/tmi/)
# Format: oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_TOKEN=oauth:DEIN_TOKEN_HIER

# Name deines Twitch-Kanals (kleingeschrieben)
TWITCH_CHANNEL=dein_kanalname

# ---- Song Requests ----
# Max. Songlänge in Minuten (Standard: 5)
MAX_SONG_DURATION_MINUTES=5

# YouTube Data API v3 Key für Längencheck (https://console.cloud.google.com/)
# Leer lassen = Längencheck deaktiviert
YOUTUBE_API_KEY=

# Zusätzliche gesperrte Begriffe im Titel, kommagetrennt (optional)
# Beispiel: BLOCKED_KEYWORDS=meme,troll,earrape
BLOCKED_KEYWORDS=

# Datei für die dauerhaft wachsende Streamliste (alle requesteten Songs)
# Standard: streamlist.txt im Bot-Verzeichnis
# Für Railway mit Volume (gemountet z.B. auf /data): STREAMLIST_FILE=/data/streamlist.txt
STREAMLIST_FILE=streamlist.txt

# Pfad zur SQLite-Datenbank (Queue + dauerhafte Streamliste)
# Standard: queue.db im Bot-Verzeichnis
# Für Railway mit Volume (gemountet z.B. auf /data): DB_PATH=/data/queue.db
DB_PATH=queue.db

# ---- Witze-Timer ----
# Interval in Minuten zwischen automatischen Witzen (Standard: 30)
JOKE_INTERVAL_MINUTES=30

# ---- Chat-Reaktionen ----
# Wahrscheinlichkeit (0.0-1.0), mit der der Bot auf eine normale Nachricht
# zufällig antwortet (Standard: 0.15 = ca. jede 7. Nachricht)
RANDOM_REPLY_CHANCE=0.15

# Ab wie vielen gleichen Emojis in Folge der Bot eine Combo ansagt (Standard: 3)
# Angesagt wird bei 3, 6, 9 ... um Spam zu vermeiden.
COMBO_THRESHOLD=3
